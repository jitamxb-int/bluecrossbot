# ---------------------------------------------------------------------------
# RAG Backend — environment configuration template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# NOTE: keep comments on their OWN lines. An inline comment after a *blank*
# value (e.g. `KEY=   # note`) is parsed as the value `# note`, not as empty.
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="Blue Cross RAG Backend"
# ENVIRONMENT: dev | prod
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_JSON: true -> JSON logs (prod), false -> pretty console (dev)
LOG_JSON=true

# --- CORS ---
# Comma-separated origins, or * for all (dev only).
CORS_ALLOW_ORIGINS=*

# --- Qdrant ---
# Local: http://localhost:6333  |  in docker-compose: http://qdrant:6333
# Qdrant Cloud: https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_URL=http://localhost:6333
# Leave blank for local; set for Qdrant Cloud.
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=blue_cross_rag_documents
QDRANT_PREFER_GRPC=false
UPSERT_BATCH_SIZE=128
# REST timeout in seconds. Raise for remote/cloud Qdrant (default httpx is only 5s).
QDRANT_TIMEOUT=60

# --- Vectors ---
# Must match the embedding model's output dimension:
#   text-embedding-3-small -> 1536
#   text-embedding-3-large -> 3072
VECTOR_SIZE=1536
# VECTOR_DISTANCE: Cosine | Dot | Euclid
VECTOR_DISTANCE=Cosine

# --- OpenAI Embeddings ---
OPENAI_API_KEY=sk-replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional override (Azure / compatible gateways). Leave blank for the default
# https://api.openai.com/v1. If set, it MUST include http:// or https://.
OPENAI_BASE_URL=
OPENAI_EMBEDDING_BATCH_SIZE=100

# --- OpenAI Chat / Generation (RAG chat answers) ---
OPENAI_CHAT_MODEL=gpt-4o

# --- MongoDB (chat session storage) ---
# Point this at your existing MongoDB / Atlas cluster. Leave blank to disable
# chat persistence (the /chat endpoint will then return a clear error).
MONGODB_URI=
MONGODB_DB=blue_cross_rag
MONGODB_CHAT_COLLECTION=chat_session
# Server-selection timeout (ms) — keep low so startup fails fast on a bad URI.
MONGODB_TIMEOUT_MS=5000

# --- Chat ---
# Recent turns replayed verbatim to the LLM (the rolling summary covers older turns).
CHAT_HISTORY_WINDOW_TURNS=10
# RAG context chunks retrieved per chat turn.
CHAT_RETRIEVAL_TOP_K=6
# Idle seconds before a session is considered timed out.
SESSION_TIMEOUT_SECONDS=1800

# --- Chunking defaults (overridable per request) ---
DEFAULT_CHUNK_SIZE=600
DEFAULT_CHUNK_OVERLAP=100
