# Virtual envs / caches
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# VCS
.git/
.gitignore

# Secrets & local data
.env
.env.*
!.env.example
logs/*
qdrant_storage/

# Frontend .env files ARE needed in the build context — Vite reads them at BUILD
# time and bakes VITE_* into the static bundle.
!frontend/.env
!admin-frontend/.env
!upload-frontend/.env

# Docs / tests not needed in the runtime image
README.md
tests/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Node deps & frontend build outputs (frontends build inside the image; keep the
# build context small and avoid clobbering the image's installed node_modules).
# NOTE: package-lock.json is intentionally NOT ignored — `npm ci` needs it.
**/node_modules/
frontend/dist/
admin-frontend/build/
upload-frontend/build/
