# syntax=docker/dockerfile:1

# ---------------------------------------------------------------------------
# Stage 1 — build the Vite frontend.
# ---------------------------------------------------------------------------
FROM node:20-alpine AS frontend-build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ ./
RUN npm run build

# ---------------------------------------------------------------------------
# Stage 2 — serve via nginx.
# ---------------------------------------------------------------------------
FROM nginx:alpine AS frontend
COPY --from=frontend-build /app/dist /usr/share/nginx/html
RUN cat > /etc/nginx/conf.d/default.conf <<'EOF'
server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Real static assets: serve the file or 404 — never fall back to index.html.
    # Prevents a missing /widget.js from being returned as SPA HTML (which the
    # browser then fails to execute as JavaScript).
    location ~* \.(?:js|mjs|css|png|jpe?g|gif|svg|ico|webp|txt|json|map|woff2?|ttf)$ {
        try_files $uri =404;
    }

    # SPA client-side routing fallback for everything else.
    location / { try_files $uri $uri/ /index.html; }
}
EOF
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
